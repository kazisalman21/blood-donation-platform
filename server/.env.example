# ⚠️  SECURITY REMINDER: If the real .env file was ever committed to version control,
# you MUST rotate ALL credentials immediately:
#   1. Change your MongoDB Atlas password
#   2. Generate a new JWT_SECRET
#   3. Generate a new Gmail App Password
# Then run: git rm --cached server/.env && git commit -m "chore: untrack .env"

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/blood-donation?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this

# Server
PORT=5000
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# Email (Nodemailer - Gmail App Password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
